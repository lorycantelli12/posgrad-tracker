# ============================================================
# PosGrad Tracker — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local — ele já está no .gitignore.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Encontre em: app.supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── OneSignal ───────────────────────────────────────────────
# Encontre em: onesignal.com → seu app → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend ──────────────────────────────────────────────────
# Encontre em: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ─────────────────────────────────────────────────────
# URL base para deep links nas push notifications
NEXT_PUBLIC_BASE_URL=https://posgrad-tracker.vercel.app
